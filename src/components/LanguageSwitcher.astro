---
// R9 i18n — replaces TranslateButtons.astro (owner ruling 2026-07-13: translation
// must live INSIDE the site, never a translate.goog proxy to another domain).
// Site-wide (mounted in Nav on every page): shows HE/EN/RU; a locale only gets
// a live link when a translated build of the CURRENT page actually exists
// (TRANSLATED_BASE_PATHS) — no dead links to not-yet-translated pages.
import { LOCALES, DEFAULT_LOCALE, localizedPath, stripLocale, hasTranslation } from '../i18n/locales';
import { UI } from '../i18n/ui-strings';
import type { Locale } from '../i18n/locales';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const barePath = stripLocale(Astro.url.pathname);
const translated = hasTranslation(barePath);
const strings = UI[locale].switcher;
---

<div class="lang-switcher notranslate" role="group" aria-label={strings.groupAria}>
  {
    LOCALES.map((l) => {
      const isCurrent = l === locale;
      const href = localizedPath(barePath, l);
      const disabled = !isCurrent && !translated;
      return disabled ? (
        <span class="lang-pill is-disabled" aria-disabled="true" title={UI[l].nav.home}>
          {strings.labels[l]}
        </span>
      ) : (
        <a
          class:list={['lang-pill', { 'is-active': isCurrent }]}
          href={href}
          lang={l}
          hreflang={l}
          aria-current={isCurrent ? 'true' : undefined}
        >
          {strings.labels[l]}
        </a>
      );
    })
  }
</div>

<style>
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .lang-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-block-size: 32px;
    padding-inline: var(--space-2);
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-on-ground) 30%, transparent);
    color: var(--color-on-ground);
    font-size: var(--text-xs);
    font-weight: var(--weight-heading);
    letter-spacing: 0.03em;
    transition:
      background var(--dur-fast) var(--ease-smooth),
      color var(--dur-fast) var(--ease-smooth),
      border-color var(--dur-fast) var(--ease-smooth);
  }
  a.lang-pill:hover,
  a.lang-pill:focus-visible {
    border-color: var(--color-on-ground);
  }
  .lang-pill.is-active {
    background: var(--color-on-ground);
    color: var(--color-ground-sunk);
    border-color: var(--color-on-ground);
  }
  .lang-pill.is-disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
</style>
