---
/* R9 i18n — the full /accessibility page body, parameterized by locale so the
   three real routes (/accessibility he, /en/accessibility, /ru/accessibility —
   src/pages/**) share one implementation instead of tripling task 16's markup.
   Owns the same styles accessibility.astro always did; only the locale
   plumbing + string extraction are new. */
import { TEL_URL, TEL_DISPLAY, EMAIL, EMAIL_URL } from '../lib/links';
import { ACCESSIBILITY } from '../i18n/pages/accessibility';
import { DEFAULT_LOCALE } from '../i18n/locales';
import type { Locale } from '../i18n/locales';

interface Props {
  locale?: Locale;
}
const { locale = DEFAULT_LOCALE } = Astro.props;
const t = ACCESSIBILITY[locale];
---

<article class="a11y-page">
  <div class="container a11y-page__measure">
    <p class="eyebrow">{t.eyebrow}</p>
    <h1>{t.h1}</h1>
    <p class="lead">{t.lead}</p>

    <section aria-labelledby="h-digital">
      <h2 id="h-digital">{t.digital.heading}</h2>
      <p>{t.digital.intro}</p>
      <ul>
        {t.digital.items.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section aria-labelledby="h-physical">
      <h2 id="h-physical">{t.physical.heading}</h2>
      <!-- Owner confirmed 2026-07-23: all three physical-access statements below
           (accessible parking, wheelchair access, accessible restrooms) are true
           in practice. Do not re-flag as unverified. -->
      <p>{t.physical.intro}</p>
      <ul>
        {t.physical.items.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section aria-labelledby="h-officer">
      <h2 id="h-officer">{t.officer.heading}</h2>
      <p>{t.officer.intro}</p>
      <p>
        {t.officer.nameLabel} {t.officer.name}<br />
        {t.officer.phoneLabel} <a href={TEL_URL}><span dir="ltr" class="notranslate">{TEL_DISPLAY}</span></a><br />
        {t.officer.emailLabel} <a href={EMAIL_URL}><span dir="ltr" class="notranslate">{EMAIL}</span></a>
      </p>
    </section>

    <section aria-labelledby="h-contact">
      <h2 id="h-contact">{t.contact.heading}</h2>
      <p>{t.contact.body}</p>
    </section>

    <footer class="a11y-page__meta">
      <p>{t.meta}</p>
    </footer>
  </div>
</article>

<style>
  .a11y-page {
    padding-block: var(--space-16);
  }
  @media (min-width: 768px) {
    .a11y-page {
      padding-block: var(--space-24);
    }
  }

  /* comfortable measure inside the shared .container — quiet dignity, no decoration */
  .a11y-page__measure {
    max-inline-size: 65ch;
    margin-inline: auto;
  }

  .eyebrow {
    color: var(--color-on-ground-soft); /* R7.1-C: sage fails on espresso */
    font-weight: var(--weight-heading);
    font-size: var(--text-sm);
    margin-block-end: var(--space-2);
  }

  /* R7.1-C Option A: this is the most text-dense page — the highest AA bar.
     Inline tel/email links get their own underline (cream reads as body text
     otherwise; color alone no longer marks a link). */
  .a11y-page a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .a11y-page a:hover,
  .a11y-page a:focus-visible {
    text-decoration-thickness: 2px;
  }

  .a11y-page h1 {
    font-size: var(--text-2xl);
    margin-block-end: var(--space-6);
  }

  .lead {
    font-size: var(--text-lg);
    margin-block-end: var(--space-12);
  }

  .a11y-page section {
    margin-block-start: var(--space-16);
  }

  .a11y-page h2 {
    font-size: var(--text-xl);
    margin-block-end: var(--space-4);
  }

  .a11y-page p {
    margin-block-end: var(--space-4);
  }

  .a11y-page ul {
    list-style: disc;
    padding-inline-start: 1.25em;
    display: grid;
    gap: var(--space-2);
    margin-block-end: var(--space-4);
  }

  .a11y-page__meta {
    margin-block-start: var(--space-16);
  }

  .a11y-page__meta p {
    color: var(--color-on-ground-soft); /* R7.1-C: sage fails on espresso */
    font-size: var(--text-sm);
    margin-block-end: 0;
  }
</style>
