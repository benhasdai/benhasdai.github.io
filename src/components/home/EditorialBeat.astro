---
// SILO home — R14-T9 "editorial beat". A prose interlude between cinema bands:
// eyebrow tag + Blender display heading + one measured paragraph, optional outline CTA.
// R14 taste pass: two distinct treatments so the two Home beats don't read identical
// and the desktop width is actually used —
//   variant="split"   → desktop two-column editorial (heading fills its half, body/CTA
//                        bottom-aligned in the other). Used for "kitchen" (has a CTA).
//   variant="feature" → centered, larger display heading, own rhythm. Used for "about".
// Scroll-reveal via the shared [data-reveal] contract (src/scripts/home.ts initReveals()):
// JS arms a pre-hidden state and flips it on IntersectionObserver entry; without JS, or
// under prefers-reduced-motion, the section stays at its CSS default (fully visible).
interface Props {
  eyebrow: string;
  heading: string;
  body: string;
  ctaHref?: string;
  ctaLabel?: string;
  variant?: 'split' | 'feature';
}

const { eyebrow, heading, body, ctaHref, ctaLabel, variant = 'split' } = Astro.props;
---

<section class:list={['ed-beat', `ed-beat--${variant}`]} data-reveal>
  <div class="container ed-beat__grid">
    <div class="ed-beat__head">
      <p class="badge-warm ed-beat__eyebrow">{eyebrow}</p>
      <h2 class="ed-beat__heading">{heading}</h2>
    </div>
    <div class="ed-beat__col">
      <p class="ed-beat__body">{body}</p>
      {ctaHref && ctaLabel && (
        <a class="btn btn-outline ed-beat__cta" href={ctaHref}>{ctaLabel}</a>
      )}
    </div>
  </div>
</section>

<style>
  .ed-beat {
    padding-block: var(--space-16);
  }
  @media (min-width: 768px) {
    .ed-beat {
      padding-block: var(--space-24);
    }
  }

  .ed-beat__eyebrow {
    margin-block-end: var(--space-6);
  }
  .ed-beat__heading {
    font-weight: var(--weight-display);
    line-height: 1.04;
    text-wrap: balance;
    margin: 0;
  }
  .ed-beat__body {
    color: var(--color-on-ground-soft); /* R7.1-C: sage fails on espresso */
    font-size: var(--text-lg);
    line-height: 1.7;
    max-inline-size: 40rem;
    margin: 0;
  }
  .ed-beat__cta {
    margin-block-start: var(--space-8);
  }

  /* ---- variant: split — two-column editorial on desktop ---- */
  .ed-beat--split .ed-beat__heading {
    font-size: clamp(var(--text-2xl), 6vw, var(--text-3xl));
    max-inline-size: 18ch;
  }
  @media (min-width: 900px) {
    .ed-beat--split .ed-beat__grid {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: clamp(var(--space-8), 6vw, var(--space-24));
      align-items: end;
    }
    .ed-beat--split .ed-beat__col {
      padding-block-end: var(--space-2);
    }
  }

  /* ---- variant: feature — centered, larger, distinct rhythm ---- */
  .ed-beat--feature {
    text-align: center;
  }
  .ed-beat--feature .ed-beat__grid {
    max-inline-size: 54rem;
  }
  .ed-beat--feature .ed-beat__heading {
    font-size: clamp(var(--text-2xl), 7vw, calc(var(--text-3xl) * 1.12));
    max-inline-size: 16ch;
    margin-inline: auto;
  }
  .ed-beat--feature .ed-beat__body {
    margin-inline: auto;
    margin-block-start: var(--space-8);
  }

  /* shared scroll-reveal contract — see src/scripts/home.ts initReveals().
     Default (no JS / reduced-motion): fully visible, no transform. */
  [data-reveal] {
    transition: opacity 0.9s var(--ease-smooth), transform 0.9s var(--ease-smooth);
  }
  [data-reveal].is-pre {
    opacity: 0;
    transform: translateY(28px);
  }
</style>
