---
// Hero — R4 "the soul round" footage. R7.5.2 "the owner's cut": the bar starts
// hidden on Home (pure cinema, full 100svh) and the booking CTA floats
// top-center over the footage; on scroll it lifts away as the bar glides down —
// two motions crossing read as the CTA being absorbed into the arriving bar.
// The floating CTA is choreo-only UI (html[data-hero-choreo]): no-JS /
// reduced-motion / static never render it — their always-visible bar carries
// booking, so exactly ONE red CTA exists at every instant (Option A).
// R8.1 "structure lock": the film itself is placeholdered (homeVideos pool,
// hero[0]) — every non-cinema element below (CTA/arrow/scrim/scrub) is
// untouched. (R15: the decorative title/tagline that used to live here were
// removed — see the R15 note further down.)
// R9 i18n: locale prop drives all human-readable text (UI.reserveCta shared
// with Nav's booking CTA; page-specific copy in i18n/pages/index.ts).
import { ontopoUrl, WHATSAPP_URL } from '../../lib/links';
import { homeVideos } from '../../lib/home-videos';
import logoRed from '../../assets/logo-red.svg?raw';
import { UI } from '../../i18n/ui-strings';
import { index as pageStrings } from '../../i18n/pages/index';
import { DEFAULT_LOCALE } from '../../i18n/locales';
import type { Locale } from '../../i18n/locales';

interface Props {
  locale?: Locale;
}
const { locale = DEFAULT_LOCALE } = Astro.props;
const t = UI[locale];
const s = pageStrings[locale];

const clip = homeVideos.hero[0];
---
<!-- Hero poster is the LCP element — the mp4 attaches lazily (home.ts initVideos). -->
{clip.poster && <link rel="preload" as="image" href={clip.poster} fetchpriority="high" />}

<section id="hero" class="hero">
  <div class="hero-media" data-hero-frame>
    {
      clip.src ? (
        <video
          class="hero-video"
          data-video
          muted
          loop
          playsinline
          preload="none"
          poster={clip.poster ?? undefined}
          aria-hidden="true"
          tabindex="-1"
        >
          <source data-src={clip.src} type="video/mp4" />
        </video>
      ) : (
        <div class="hero-placeholder" role="presentation" style={`--band-tint: ${clip.tint}`}>
          <span class="hero-placeholder-label">{s.heroPlaceholderLabel}</span>
        </div>
      )
    }
  </div>

  <div class="hero-scrim" aria-hidden="true"></div>

  <!-- floating top row — logo (start) / booking CTA (center) / mobile
       whatsapp+burger (end); lifts away together when the bar arrives (the
       exchange). A 3-column grid (matching Nav's own desktop bar) keeps the
       CTA truly centered regardless of how wide the two edge zones are —
       independent absolute-positioned siblings (the pre-2026-07-23 shape)
       drifted out of alignment because each had its own hand-picked offset.
       Rendered for everyone, SHOWN only under html[data-hero-choreo] (armed
       pre-paint by Nav's inline script). -->
  <div class="hero-topbar">
    <!-- R14-T8 (interim): a persistent wordmark at the hero so a first-timer
         sees the brand BEFORE the bar arrives (review H1). The print wordmark
         is used UNCHANGED (BRANDING BAN: presentation only, no mark surgery).
         Decorative (aria-hidden): the h1 + the bar's real logo-link carry
         identity for AT. Final identity treatment is a later pass (owner:
         "solve it properly later"). -->
    <span class="hero-mark" aria-hidden="true">
      <span class="logo-art" set:html={logoRed} />
    </span>

    <a class="hero-book btn btn-primary" href={ontopoUrl(locale)} target="_blank" rel="noopener">{t.reserveCta}</a>

    <!-- mobile-only (<1024, matching Nav's own burger breakpoint): a
         WhatsApp icon + a burger that proxies the real drawer trigger inside
         Nav.astro. nav.ts's initDrawer() only queries [data-burger] scoped
         inside .nav-root, so this can't be wired the same way — it forwards
         its click to the real button instead of re-implementing the drawer
         (owner, 2026-07-23: "the hamburger needs to be represented from the
         start, not only on scroll — add a WhatsApp icon beside it too"). -->
    <div class="hero-topbar__actions">
      <a class="hero-icon" href={WHATSAPP_URL()} target="_blank" rel="noopener" aria-label={t.nav.whatsappAria}>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z" />
        </svg>
      </a>
      <button
        class="hero-icon"
        type="button"
        data-hero-burger-proxy
        aria-label={t.nav.burgerLabel}
      >
        <span class="burger-lines" aria-hidden="true"><span></span><span></span></span>
      </button>
    </div>
  </div>

  <!-- R15 (owner, 2026-07-23): decorative title/tagline overlay removed from
       the footage. The h1 stays — it carries identity for AT/SEO. -->
  <div class="hero-content">
    <h1 class="visually-hidden">{s.hero.h1}</h1>
  </div>
</section>

<style>
  .hero {
    position: relative;
    /* R7.5.2: full viewport — the bar no longer reserves space on Home (fixed
       + hidden until scroll). No-JS/reduced-motion see sticky-bar + 100svh
       hero, which just scrolls — acceptable, never broken. */
    min-block-size: 100svh;
    overflow: hidden;
    isolation: isolate;
  }

  /* ============ floating top row + the exchange (Emil spec, R16 3-zone
     rework 2026-07-23) ============
     Hidden by default — choreo-only UI. One wrapper now owns the show/hide/
     fade-away transition for all three zones together (logo, CTA, mobile
     actions), so they can never drift out of sync the way two independently
     offset absolutely-positioned siblings did (that's what caused the
     logo/CTA misalignment — space-6 vs space-8, two hand-picked numbers that
     don't move together). Grid, not flex space-between: a 1fr/auto/1fr track
     keeps the center zone TRULY centered regardless of how wide the two edge
     zones are (same technique as Nav's own desktop bar). */
  .hero-topbar {
    display: none;
    position: absolute;
    z-index: 3; /* above scrim (1) and content (2) */
    inset-inline: 0;
    inset-block-start: var(--space-6);
    padding-inline: var(--space-6);
    align-items: center;
    will-change: transform, opacity, filter;
    transition:
      transform 300ms cubic-bezier(0.23, 1, 0.32, 1),
      opacity 300ms cubic-bezier(0.23, 1, 0.32, 1),
      filter 300ms cubic-bezier(0.23, 1, 0.32, 1);
  }
  :global(html[data-hero-choreo]) .hero-topbar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
  }
  /* the exchange: as the bar glides down (450ms), the whole row drifts up,
     fades and blurs away over 300ms strong ease-out — the blur masks the
     swap, the two motions crossing read as absorption. Pure transitions:
     interruptible and fully reversible on scroll-up, no measurement, no GSAP.
     visibility flips AFTER the fade (drawer pattern) so keyboard/AT never
     reach an invisible control; on reverse it flips back instantly (base
     transition omits it). */
  :global(html[data-hero-choreo].is-revealed) .hero-topbar {
    transform: translateY(-18px);
    opacity: 0;
    filter: blur(2px);
    pointer-events: none;
    visibility: hidden;
    transition:
      transform 300ms cubic-bezier(0.23, 1, 0.32, 1),
      opacity 300ms cubic-bezier(0.23, 1, 0.32, 1),
      filter 300ms cubic-bezier(0.23, 1, 0.32, 1),
      visibility 0s linear 300ms;
  }

  /* ---- logo (grid start) — R14-T8 persistent hero wordmark (interim) ----
     The print wordmark, unchanged (BRANDING BAN). */
  .hero-mark {
    display: block;
    justify-self: start;
    block-size: 36px;
    aspect-ratio: 273.33 / 135.37;
  }
  .hero-mark .logo-art {
    display: block;
    block-size: 100%;
  }
  .hero-mark .logo-art :global(svg) {
    display: block;
    block-size: 100%;
    inline-size: 100%;
    /* linen — the hero-over-video display tier (holds AA over bright footage);
       red stays reserved for the CTA fill, matching the bar's cream wordmark. */
    color: var(--color-ink-display);
    /* legibility insurance over the brightest moving frames (the bar's own
       wordmark rides a blur; this one sits raw on footage) */
    filter: drop-shadow(0 1px 10px color-mix(in srgb, var(--color-ground-sunk) 60%, transparent));
  }
  @media (min-width: 1024px) {
    .hero-mark { block-size: 44px; }
  }

  /* ---- booking CTA (grid center) ---- */
  .hero-book.btn {
    justify-self: center;
    inline-size: fit-content;
    box-shadow: 0 8px 28px color-mix(in srgb, var(--color-ground-sunk) 45%, transparent);
    transition: background var(--dur-fast) var(--ease-smooth), color var(--dur-fast) var(--ease-smooth);
  }
  .hero-book.btn:active {
    transform: scale(0.97); /* Emil: press feedback on the primary */
  }

  /* ---- mobile whatsapp+burger cluster (grid end, <1024 only — matches
     Nav's own burger breakpoint) ---- */
  .hero-topbar__actions {
    display: none;
    justify-self: end;
    align-items: center;
    gap: var(--space-2);
  }
  @media (max-width: 1023.98px) {
    .hero-topbar__actions {
      display: flex;
    }
  }
  .hero-icon {
    display: grid;
    place-items: center;
    inline-size: 44px;
    block-size: 44px;
    color: var(--color-ink-display);
    filter: drop-shadow(0 1px 10px color-mix(in srgb, var(--color-ground-sunk) 60%, transparent));
    border: 0;
    background: none;
    padding: 0;
    cursor: pointer;
  }
  .hero-icon .burger-lines {
    display: block;
    position: relative;
    inline-size: 20px;
    block-size: 14px;
  }
  .hero-icon .burger-lines span {
    position: absolute;
    inset-inline: 0;
    block-size: 2px;
    border-radius: 1px;
    background: currentColor;
  }
  .hero-icon .burger-lines span:first-child { inset-block-start: 2px; }
  .hero-icon .burger-lines span:last-child { inset-block-start: 10px; }

  /* full-bleed footage — [data-hero-frame] carries the gentle pin-scrub recede */
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    will-change: transform;
  }
  .hero-video {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: center;
    background: var(--color-ground-sunk); /* R7.1-C: poster fallback must stay dark regardless of the ground flip */
  }

  /* R8.1: film-slot placeholder — stands in for the hero clip until real
     footage lands (home-videos.ts pool). Same box as .hero-video. */
  .hero-placeholder {
    display: grid;
    place-items: center;
    inline-size: 100%;
    block-size: 100%;
    background: var(--band-tint);
    outline: 1px dashed color-mix(in srgb, var(--color-on-ground-soft) 40%, transparent);
    outline-offset: -1px;
  }
  .hero-placeholder-label {
    font-weight: var(--weight-heading);
    font-size: var(--text-sm);
    letter-spacing: 0.14em;
    color: var(--color-on-ground-soft);
  }

  /* dark scrim rising from the base — deepened through the 42–60% band (where
     the tagline sits at 55svh) so cream text holds AA over the brightest
     moving footage, not just over the dark frames.
     R7.1-C: mixed on --color-ground-sunk (a fixed dark), not --color-text —
     --color-text is now cream and a cream-tinted scrim would wash the video pale. */
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--color-ground-sunk) 90%, transparent) 0%,
      color-mix(in srgb, var(--color-ground-sunk) 72%, transparent) 20%,
      color-mix(in srgb, var(--color-ground-sunk) 54%, transparent) 42%,
      color-mix(in srgb, var(--color-ground-sunk) 36%, transparent) 60%,
      color-mix(in srgb, var(--color-ground-sunk) 12%, transparent) 74%,
      transparent 86%
    );
  }

  /* content cluster sits below the center-stage mark (logo center ≈ 40svh) —
     now just the visually-hidden h1 (R15: decorative title/tagline removed). */
  .hero-content {
    position: absolute;
    z-index: 2;
    inset-inline: 0;
    inset-block-start: 55svh;
    display: grid;
    justify-items: center;
    gap: var(--space-6);
    padding-inline: var(--space-6);
    text-align: center;
  }
</style>
