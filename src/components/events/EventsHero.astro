---
// R3 — events hero: the headline, alone. Everything else lives inside the
// three package sections below (user ruling).
// R9 i18n — headline text now comes from the events strings module.
import { events } from '../../i18n/pages/events';
import { DEFAULT_LOCALE } from '../../i18n/locales';
import type { Locale } from '../../i18n/locales';

interface Props {
  locale?: Locale;
}
const { locale = DEFAULT_LOCALE } = Astro.props;
const t = events[locale];
---
<section class="events-hero" aria-labelledby="events-title">
  <div class="container">
    <h1 id="events-title" data-intro>{t.heroTitle}</h1>
  </div>
</section>

<style>
  .events-hero {
    padding-block: var(--space-16) var(--space-8);
  }
  @media (min-width: 768px) {
    .events-hero {
      padding-block: var(--space-24) var(--space-12);
    }
  }

  h1 {
    font-weight: var(--weight-display);
    font-size: clamp(var(--text-2xl), 5vw + 1.25rem, var(--text-3xl));
    line-height: 1.08;
    max-inline-size: 16ch;
  }
</style>
