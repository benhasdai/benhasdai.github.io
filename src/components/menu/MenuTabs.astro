---
/* Task 11 — menu tab bar.
   No-JS baseline: anchor links to the stacked sections below.
   menu.ts upgrades it to a real ARIA tablist (roles, aria-selected, keyboard).
   Mobile + JS: fixed to the bottom edge — within one-handed thumb reach at the table. */
import type { TabDef } from './menu-data';
import { UI } from '../../i18n/ui-strings';
import { DEFAULT_LOCALE } from '../../i18n/locales';
import type { Locale } from '../../i18n/locales';

interface Props {
  tabs: TabDef[];
  active?: string;
  locale?: Locale;
}

const { tabs, active = tabs[0]?.id, locale = DEFAULT_LOCALE } = Astro.props;
---

<nav class="menu-tabs" aria-label={UI[locale].menu.tablistAria}>
  <ul class="menu-tabs-list" role="list" data-menu-tablist>
    {
      tabs.map((t) => (
        <li class="menu-tabs-item">
          <a
            id={`tab-${t.id}`}
            class:list={['menu-tab', { 'is-active': t.id === active }]}
            href={`#panel-${t.id}`}
            data-menu-tab={t.id}
          >
            {t.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
