---
// R9 i18n — English /en/accessibility route (real page, never translate.goog).
// Same body as the Hebrew page — see components/AccessibilityPage.astro.
import Layout from '../../layouts/Layout.astro';
import AccessibilityPage from '../../components/AccessibilityPage.astro';
import { ACCESSIBILITY } from '../../i18n/pages/accessibility';

const t = ACCESSIBILITY.en;
---

<Layout title={t.pageTitle} description={t.pageDescription} current="accessibility" navMode="static" locale="en">
  <AccessibilityPage locale="en" />
</Layout>
